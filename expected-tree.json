    {
      "path": "per-module-override",
      "description": "Per-module strict conflict manager on commons-logging; latest-revision default elsewhere",
      "catalog_pattern": "ivy-conflict-manager-mismatch",
      "catalog_id": "E1",
      "conflict_manager": {
        "default": "latest-revision",
        "per_module": [
          {
            "organisation": "commons-logging",
            "name": "commons-logging",
            "conflict_manager": "strict"
          }
        ]
      },
      "expected_direct_dependencies": [
        {
          "groupId": "org.apache.httpcomponents",
          "artifactId": "httpclient",
          "version": "4.5.14",
          "conf": "compile",
          "source": "registry"
        },
        {
          "groupId": "commons-beanutils",
          "artifactId": "commons-beanutils",
          "version": "1.8.3",
          "conf": "compile",
          "source": "registry"
        }
      ],
      "expected_transitive_dependencies": [
        {
          "groupId": "commons-logging",
          "artifactId": "commons-logging",
          "version": "1.2",
          "source": "registry",
          "conflict_note": "strict fires — also requested at 1.1.1 via commons-beanutils; latest-revision tentative winner is 1.2"
        },
        {
          "groupId": "org.apache.httpcomponents",
          "artifactId": "httpcore",
          "version": "4.4.16",
          "source": "registry"
        },
        {
          "groupId": "commons-codec",
          "artifactId": "commons-codec",
          "version": "1.15",
          "source": "registry"
        },
        {
          "groupId": "commons-collections",
          "artifactId": "commons-collections",
          "version": "3.2.2",
          "source": "registry"
        }
      ],
      "warnings": [
        {
          "type": "conflict_manager_strict_failure",
          "module": "commons-logging:commons-logging",
          "requested_versions": ["1.2", "1.1.1"],
          "requestors": [
            "org.apache.httpcomponents:httpclient:4.5.14 -> 1.2",
            "commons-beanutils:commons-beanutils:1.8.3 -> 1.1.1"
          ],
          "tentative_winner": "1.2",
          "mend_regression_signal": "If Mend emits commons-logging:1.2 with NO warning entry, it has assumed latest-revision globally and ignored the per-module strict override. Flag as regression against E1."
        }
      ]
    },

